%--- initialize macros
\newcommand{\TestTitle}{}
\newcommand{\TestDate}{\today}
\newcommand{\TestRange}{}

\newcommand{\SetTitle}[1]{\renewcommand{\TestTitle}{#1}}
\newcommand{\SetDate}[1]{\renewcommand{\TestDate}{#1}}
\newcommand{\SetRange}[1]{\renewcommand{\TestRange}{#1}}

%--- set new counter
\newcounter{testprob}
\setcounter{testprob}{1}
\NewDocumentCommand{\Prob}{o}{%
  \IfValueTF{#1}{%
    \setcounter{testprob}{#1}% 引数があればその番号にセット
  }{}%
  \noindent\hspace{-13pt}\fbox{\textbf{\thetestprob}}\hspace{9pt}%
  \stepcounter{testprob}%
}


%--- main macro : if page number is odd or even ---%
\newcommand{\MakeTestPage}[2]{%
  \ifodd\value{page}\relax%
  %--- for odd pages (name side)
    \begin{tabularx}{0.98\textwidth}{|X|X|}
    \hline
      \multicolumn{1}{|>{\hsize=\hsize}X}{%
      \rule[-9pt]{0pt}{25pt}%
      \noindent%
      \begin{minipage}[]{0.5\textwidth}
        \rule[-3pt]{0pt}{6pt}\footnotesize\TestRange%
      \end{minipage}
      } & 
      \multicolumn{1}{>{\hsize=\hsize\raggedleft\arraybackslash}X|}{%
      \noindent%
      \vrule width 0.4pt height 16pt depth 9pt\hspace{15pt}
      \raisebox{-6pt}{\footnotesize 組}%
      \vrule width 0.4pt height 16pt depth 9pt\hspace{15pt}
      \raisebox{-6pt}{\footnotesize 番}\vrule width 0.4pt height 16pt depth 9pt
      \begin{minipage}[]{7pt}\centering\footnotesize 氏\\名\end{minipage}%
      \vrule width 0.4pt height 16pt depth 9pt\hspace{100pt}
      \vrule width 0.4pt height 16pt depth 9pt\hspace*{0.4pt}%
      \vrule width 0.4pt height 16pt depth 9pt\hspace{15pt}
      \raisebox{-6pt}{\footnotesize 点}%
      } \\ \hline
      \hspace{8pt}
      \rule{0pt}{13pt}
      \begin{minipage}[t][\dimexpr\textheight-35pt\relax]{260pt}
        \setlength{\parindent}{1\zw}
        %\noindent\hspace{-13pt}%
        #1%
      \end{minipage}%
      & \hspace{9.5pt}
      \begin{minipage}[t][\dimexpr\textheight-35pt\relax]{260pt}
        \setlength{\parindent}{1\zw}
        %\noindent\hspace{-13pt}%
        #2%
      \end{minipage}\\
    \hline
    \end{tabularx}%
  \else%
  %--- even pages
    \begin{tabularx}{0.98\textwidth}{|X|X|}
    \hline
      \multicolumn{1}{|>{\hsize=\hsize}X}{%
      \rule[-9pt]{0pt}{25pt}%
      \noindent\hspace*{5pt}\textbf{\TestTitle}%
      } & 
      \multicolumn{1}{>{\hsize=\hsize\raggedleft\arraybackslash}X|}{%
      \noindent%
      \textbf{\TestDate}} \\ \hline
      \hspace{8pt}
      \rule{0pt}{13pt}
      \begin{minipage}[t][\dimexpr\textheight-35pt\relax]{260pt}
        \setlength{\parindent}{1\zw}
        %\noindent\hspace{-13pt}%
        #1%
      \end{minipage}%
      & \hspace{9.5pt}
      \begin{minipage}[t][\dimexpr\textheight-35pt\relax]{260pt}
        \setlength{\parindent}{1\zw}
        %\noindent\hspace{-13pt}
        #2%
      \end{minipage}\\
    \hline
    \end{tabularx}%
  \fi%
  \clearpage
}
